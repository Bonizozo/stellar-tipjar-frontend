# Backend REST API base URL (required — must be a valid URL)
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket server URL (required — must be a valid URL)
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Stellar network: testnet | public  (default: testnet)
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Override Horizon server URL (optional — derived from network if omitted)
# NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Public site URL (default: https://stellar-tipjar.app)
NEXT_PUBLIC_SITE_URL=https://stellar-tipjar.app

# Public app URL if different from site URL (optional)
# NEXT_PUBLIC_APP_URL=https://app.stellar-tipjar.app

# Google Analytics tracking ID (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Sentry DSN (optional)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/yyy

# VAPID public key for web push notifications (optional)
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
